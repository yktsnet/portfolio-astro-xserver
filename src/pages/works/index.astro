---
import MainLayout from '../../layouts/MainLayout.astro';
import Logo from '../../layouts/Logo.astro';
import { works } from '../../data/works';
import { getLucideIcon } from '../../lib/lucide';

const worksResolved = works.map(work => ({
  ...work,
  iconPath: getLucideIcon(work.icon),
}));
---
<MainLayout title="Works" description="実際に作ったものをまとめています。">
  <section>
    <h1 class="mb-3 text-xl font-semibold text-zinc-900 dark:text-poi-focus">Works</h1>
    <p class="font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
      個人・受託で実際に作り、現在も運用しているものをまとめています。
    </p>
  </section>

  <section class="mt-10 space-y-4">
    {worksResolved.map((work) => (
      <div
        class="rounded-xl border border-zinc-200 border-l-2 bg-white p-5 transition-colors hover:border-zinc-300 dark:border-poi-border dark:bg-poi-panel dark:hover:border-zinc-600"
        style={`border-left-color: ${work.color};`}
      >
        <div class="flex items-start gap-4">
          <div
            class="mt-0.5 shrink-0 flex items-center justify-center w-9 h-9 rounded-lg"
            style={`background:${work.color}18`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16" height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="1.5"
              stroke-linecap="round"
              stroke-linejoin="round"
              style={`color:${work.color}`}
              set:html={work.iconPath}
            />
          </div>
          <div class="min-w-0 flex-1">
            <span
              class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-mono"
              style={`background: ${work.color}15; color: ${work.color};`}
            >
              {work.tag}
            </span>
            <h2 class="mt-2 text-base font-semibold text-zinc-900 dark:text-poi-focus">
              {work.title}
            </h2>
            <p class="mt-1.5 font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
              {work.description}
            </p>
            <div class="mt-3 flex flex-wrap gap-x-5 gap-y-1 font-mono text-xs">
              {work.links.map((link) => (
                <a
                  class="hover:underline underline-offset-2"
                  style={`color: ${work.color};`}
                  href={link.href}
                  target={link.external ? "_blank" : undefined}
                  rel={link.external ? "noopener noreferrer" : undefined}
                >
                  {link.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    ))}
  </section>

  <!-- このサイトについて -->
  <section class="mt-16 border-t border-zinc-200 pt-10 dark:border-zinc-700/40">
    <h2 class="text-xs font-mono text-zinc-500 dark:text-zinc-400">このサイトについて</h2>
    <p class="mt-3 font-sans text-sm leading-7 text-zinc-600 dark:text-poi-muted">
      エンジニアのポートフォリオ兼技術ブログ。Astro + Cloudflare Pages で構築。ロゴは SVG パスのみで描いた自作で、3本の曲線が互いに邪魔せず一点で交わる形は、「人が主役で、技術は裏で静かに支える」という自分なりの信条を表しています。
    </p>
    <div class="mt-6 flex flex-col gap-6 sm:flex-row sm:items-stretch">
      <div class="flex items-center justify-center rounded-xl bg-zinc-100/50 p-8 dark:bg-zinc-900/30 sm:basis-1/4 group/logo">
        <Logo size={64} class="h-16 w-16 transition-transform duration-500 ease-out group-hover/logo:rotate-180" />
      </div>
      <div class="relative min-w-0 sm:basis-3/4">
        <span class="absolute -top-3 left-4 z-10 bg-white px-2 text-[10px] font-bold uppercase tracking-widest text-zinc-500 dark:bg-poi-base dark:text-zinc-500">
          SVG Source
        </span>
        <div class="overflow-hidden rounded-lg bg-zinc-950 shadow-lg">
          <pre class="overflow-x-auto p-5 text-[11px] leading-relaxed text-poi-accent"><code>{`<svg viewBox="0 0 24 24" fill="none">
  <path d="M22 12a1 1 0 0 1-10 0
           a1 1 0 0 0-10 0"
        stroke="#5de4c7" />
  <path d="M7 20.7a1 1 0 1 1 5-8.7
           a1 1 0 1 0 5-8.6"
        stroke="#d482ab" />
  <path d="M7 3.3a1 1 0 1 1 5 8.6
           a1 1 0 1 0 5 8.6"
        stroke="#89ddff" />
  <circle cx="12" cy="12" r="2"
        stroke="#cdffb8" />
</svg>`}</code></pre>
        </div>
      </div>
    </div>
    <div class="mt-5 font-mono text-xs">
      <a class="text-light-accent dark:text-poi-accent hover:underline underline-offset-2"
         href="https://github.com/yktsnet/portfolio-astro" target="_blank" rel="noopener noreferrer">GitHub</a>
    </div>
  </section>

</MainLayout>
