---
import MainLayout from "../../layouts/MainLayout.astro";
import { photos } from "../../data/photos";

// Skip missing files at build time
const existing = import.meta.glob("/public/images/photos/*.webp");
const existingNames = new Set(
  Object.keys(existing).map((p) => p.split("/").pop()!)
);
const validPhotos = photos.filter((p) => existingNames.has(p.src));

// Group consecutive photos with same location + date
type Photo = typeof validPhotos[number];
type Section = { location: string; date: string; items: Photo[] };
const sections: Section[] = [];
for (const photo of validPhotos) {
  const existing = sections.find(
    s => s.location === photo.location && s.date === photo.date
  );
  if (existing) {
    existing.items.push(photo);
  } else {
    sections.push({ location: photo.location, date: photo.date, items: [photo] });
  }
}
sections.sort((a, b) => b.date.localeCompare(a.date));

// Split a flat array into alternating rhythm chunks: [full, pair, full, pair, ...]
// chunk pattern per 3: [1 full] [2 side-by-side]
function toRhythmChunks(items: Photo[]) {
  const chunks: { type: "full"; photo: Photo } | { type: "pair"; photos: [Photo, Photo] } extends infer C ? C[] : never = [];
  let i = 0;
  while (i < items.length) {
    // full
    chunks.push({ type: "full", photo: items[i] });
    i++;
    // pair (if enough remain)
    if (i < items.length) {
      if (i + 1 < items.length) {
        chunks.push({ type: "pair", photos: [items[i], items[i + 1]] });
        i += 2;
      } else {
        // only one left — render as full
        chunks.push({ type: "full", photo: items[i] });
        i++;
      }
    }
  }
  return chunks;
}
---

<MainLayout title="Photos">
  <div class="-mx-4 sm:-mx-8">
    {sections.map((section) => (
      <section class="mb-20">
        <!-- Section header — no border -->
        <div class="flex items-center gap-3 px-4 sm:px-8 pb-4">
          <span class="font-mono text-xs text-light-accent dark:text-poi-accent tracking-wide">
            {section.location}
          </span>
          <span class="font-mono text-xs text-zinc-300 dark:text-zinc-600" aria-hidden="true">·</span>
          <span class="font-mono text-xs text-zinc-400 dark:text-poi-muted/70">
            {section.date}
          </span>
          <span class="font-mono text-xs text-zinc-400 dark:text-zinc-500 ml-auto">
            {section.items.length}
          </span>
        </div>

        <!-- Alternating rhythm: full → 2up → full → 2up … -->
        <div class="flex flex-col gap-3">
          {toRhythmChunks(section.items).map((chunk) =>
            chunk.type === "full" ? (
              <button
                class="photo-btn block w-full overflow-hidden cursor-zoom-in group"
                data-src={`/images/photos/${chunk.photo.src}`}
                data-meta={`${chunk.photo.location} · ${chunk.photo.date}`}
                aria-label={`Open photo — ${chunk.photo.location}`}
                type="button"
              >
                <img
                  src={`/images/photos/${chunk.photo.src}`}
                  alt={chunk.photo.location}
                  loading="lazy"
                  decoding="async"
                  class="w-full h-auto block transition-opacity duration-200 group-hover:opacity-75"
                />
              </button>
            ) : (
              <div class="grid grid-cols-2 gap-2">
                {chunk.photos.map((photo) => (
                  <button
                    class="photo-btn block w-full overflow-hidden cursor-zoom-in group"
                    data-src={`/images/photos/${photo.src}`}
                    data-meta={`${photo.location} · ${photo.date}`}
                    aria-label={`Open photo — ${photo.location}`}
                    type="button"
                  >
                    <img
                      src={`/images/photos/${photo.src}`}
                      alt={photo.location}
                      loading="lazy"
                      decoding="async"
                      class="w-full h-auto block transition-opacity duration-200 group-hover:opacity-75"
                    />
                  </button>
                ))}
              </div>
            )
          )}
        </div>
      </section>
    ))}
  </div>

  <!-- Lightbox -->
  <div id="lightbox" role="dialog" aria-modal="true" aria-label="Photo viewer">
    <img id="lightbox-img" src="" alt="" />
    <p id="lightbox-meta" class="lightbox-meta"></p>
  </div>

  <!-- Back to top -->
  <button
    class="fixed end-4 bottom-8 z-50 flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border-2 border-transparent bg-zinc-200 dark:bg-zinc-700 text-zinc-600 dark:text-zinc-300 opacity-0 transition-all duration-300 hover:border-light-accent dark:hover:border-poi-accent sm:end-8 sm:h-12 sm:w-12"
    id="to-top-btn"
  >
    <span class="sr-only">Back to top</span>
    <svg aria-hidden="true" class="h-6 w-6" fill="none" focusable="false"
      stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
      <path d="M4.5 15.75l7.5-7.5 7.5 7.5" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </button>
</MainLayout>

<style>
  #lightbox {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.92);
    z-index: 9999;
    cursor: zoom-out;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 1rem;
  }
  #lightbox.open {
    display: flex;
  }
  #lightbox img {
    max-width: 92vw;
    max-height: 88vh;
    object-fit: contain;
  }
  .lightbox-meta {
    font-family: "Fira Code", monospace;
    font-size: 0.7rem;
    color: rgba(166, 172, 205, 0.55);
    letter-spacing: 0.05em;
  }
</style>

<script>
  const lightbox = document.getElementById("lightbox")!;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const lightboxMeta = document.getElementById("lightbox-meta")!;

  document.querySelectorAll<HTMLButtonElement>(".photo-btn").forEach((btn) => {
    btn.addEventListener("click", () => {
      lightboxImg.src = btn.dataset.src ?? "";
      lightboxMeta.textContent = btn.dataset.meta ?? "";
      lightbox.classList.add("open");
      document.body.style.overflow = "hidden";
    });
  });

  lightbox.addEventListener("click", close);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") close();
  });

  function close() {
    lightbox.classList.remove("open");
    document.body.style.overflow = "";
  }

  // Back to top
  const scrollBtn = document.getElementById("to-top-btn") as HTMLButtonElement;
  window.addEventListener("scroll", () => {
    const show = window.scrollY > 300;
    scrollBtn.style.opacity = show ? "1" : "0";
    scrollBtn.style.pointerEvents = show ? "auto" : "none";
  });
  scrollBtn.addEventListener("click", () => window.scrollTo({ top: 0, behavior: "smooth" }));
</script>
