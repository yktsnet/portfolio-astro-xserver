---
import type { CollectionEntry } from "astro:content";
import type { HTMLTag, Polymorphic } from "astro/types";
import FormattedDate from "../FormattedDate.astro";
import { getLucideIcon } from "../../lib/lucide";
import { getPostVisualMeta } from "../../data/works";

type Props<Tag extends HTMLTag> = Polymorphic<{ as: Tag }> & {
  post: CollectionEntry<"post">;
  withDesc?: boolean;
  cardMode?: boolean;
};

const { as: Tag = "div", post, withDesc = false, cardMode = false } = Astro.props;
const visual = getPostVisualMeta(post.id, post.data.icon ?? "code");
const postUrl = `/posts/${post.id}/`;
const svgContent = getLucideIcon(visual.icon);
const borderStyle = `border-left-color:${visual.color}`;
const iconStyle = `color:${visual.color}`;
---

{cardMode && (
  <a href={postUrl} class="group flex flex-col gap-3 rounded-xl border border-zinc-200 border-l-2 bg-white p-4 transition-colors hover:border-zinc-300 dark:border-poi-border dark:border-l-2 dark:bg-poi-panel dark:hover:border-poi-border" style={borderStyle}>
    <div class="flex h-12 w-12 items-center justify-center" style={iconStyle}>
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" set:html={svgContent} />
    </div>
    <div>
      {post.data.draft && <span class="text-xs text-red-500">(Draft) </span>}
      <p class="text-sm font-semibold leading-snug text-zinc-900 dark:text-poi-focus">{post.data.title}</p>
      <p class="mt-1 text-xs text-zinc-500 dark:text-zinc-400"><FormattedDate date={post.data.publishDate} /></p>
    </div>
  </a>
)}

{!cardMode && (
  <>
    <FormattedDate class="min-w-[120px] font-semibold text-zinc-500 dark:text-poi-muted/70" date={post.data.publishDate} />
    <Tag>
      {post.data.draft && <span class="text-red-500">(Draft) </span>}
      <a class="cactus-link" href={postUrl}>{post.data.title}</a>
    </Tag>
    {withDesc && <q class="line-clamp-3 italic">{post.data.description}</q>}
  </>
)}
